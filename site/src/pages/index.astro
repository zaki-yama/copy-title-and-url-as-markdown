---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import ChromeIcon from "../components/icons/ChromeIcon.astro";
import EdgeIcon from "../components/icons/EdgeIcon.astro";
import screenshot from "../assets/screenshot.png";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const storeUrl =
  "https://chrome.google.com/webstore/detail/copy-title-and-url-as-mar/fpmbiocnfbjpajgeaicmnjnnokmkehil";
const edgeStoreUrl =
  "https://microsoftedge.microsoft.com/addons/detail/copy-title-and-url-as-mar/cepmaeppcipafbfjonahpohfmolliblp";
const repoUrl = "https://github.com/zaki-yama/copy-title-and-url-as-markdown";

const features = [
  {
    icon: "⌘",
    title: "One shortcut",
    body: "Press Ctrl+Shift+C and the current tab becomes [title](url) in your clipboard. No selecting, no retyping.",
  },
  {
    icon: "{ }",
    title: "Custom templates",
    body: "Compose any format with ${title} and ${url} placeholders — Markdown, HTML, plain text, wiki syntax.",
  },
  {
    icon: "≡",
    title: "Three formats",
    body: "Keep up to three templates, each bound to its own shortcut: Ctrl+Shift+C, +1, and +2.",
  },
  {
    icon: "◐",
    title: "Dark mode ready",
    body: "The toolbar icon is designed to stay legible in both light and dark browser themes.",
  },
  {
    icon: "○",
    title: "Private by design",
    body: "No accounts, no tracking, no network calls. It reads the active tab only when you copy.",
  },
];

const steps = [
  ["Install", "Add the extension from the Chrome Web Store or Microsoft Edge Add-ons."],
  ["Copy", "Click the toolbar icon or press Ctrl+Shift+C on any page."],
  ["Customize", "Edit your format templates on the options page."],
];
---

<Layout title="Copy Title and Url as Markdown Style — Chrome Extension">
  <!-- Hero -->
  <section class="relative overflow-hidden text-center">
    <div
      class="pointer-events-none absolute -top-44 left-1/2 h-[500px] w-[900px] -translate-x-1/2 rounded-full bg-[radial-gradient(ellipse_at_center,rgba(13,147,115,0.09),transparent_65%)]"
    >
    </div>
    <div class="mx-auto max-w-5xl px-6 pt-26 pb-22">
      <span
        class="rise rise-1 inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent-soft px-3.5 py-1.5 text-[13px] font-medium text-accent"
      >
        ✦ Free Chrome &amp; Edge extension
      </span>
      <h1
        class="rise rise-2 mx-auto mt-6 max-w-[680px] text-[clamp(38px,6vw,58px)] leading-[1.08] font-semibold tracking-[-0.035em] text-balance"
      >
        The fastest way to copy a page as a <span class="text-accent">Markdown link</span>
      </h1>
      <p class="rise rise-3 mx-auto mt-5 max-w-[540px] text-lg text-muted">
        Turn the current tab into
        <code class="rounded-md border border-line bg-soft px-1.5 py-0.5 font-mono text-[0.85em] text-ink"
          >[title](url)</code
        >
        with a single keyboard shortcut. Built for people who live in Markdown.
      </p>
      <div class="rise rise-4 mt-9 flex flex-wrap items-center justify-center gap-3.5">
        <a
          href={storeUrl}
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 rounded-[10px] bg-ink px-5.5 py-3 text-[15px] font-medium text-white shadow-sm transition-all hover:-translate-y-px hover:bg-ink-hover"
        >
          <ChromeIcon />
          Add to Chrome
        </a>
        <a
          href={edgeStoreUrl}
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 rounded-[10px] bg-ink px-5.5 py-3 text-[15px] font-medium text-white shadow-sm transition-all hover:-translate-y-px hover:bg-ink-hover"
        >
          <EdgeIcon />
          Add to Edge
        </a>
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener"
          class="rounded-[10px] bg-accent px-5.5 py-3 text-[15px] font-medium text-white shadow-sm transition-all hover:-translate-y-px hover:bg-accent/90"
        >
          Star on GitHub ★
        </a>
      </div>

      <!-- Clipboard demo -->
      <div
        class="rise rise-5 mx-auto mt-16 max-w-[640px] overflow-hidden rounded-xl border border-line bg-white text-left shadow-[0_1px_2px_rgba(14,17,22,0.04),0_12px_40px_-12px_rgba(14,17,22,0.12)]"
      >
        <div
          class="flex items-center justify-between border-b border-line bg-soft px-4 py-2.5 text-[12.5px] text-faint"
        >
          <span>clipboard</span>
          <span class="text-xs font-semibold text-accent">✓ Copied</span>
        </div>
        <pre
          class="overflow-x-auto px-5 py-5.5 font-mono text-[13.5px] leading-[1.9] text-muted">## Reading list
- <span class="font-medium text-ink">[Astro Docs — Build faster websites]</span>(<span class="text-accent">https://docs.astro.build/</span>)
- <span class="font-medium text-ink">[Copy Title and Url as Markdown Style]</span>(<span class="text-accent">https://chrome.google.com/webstore/…</span>)</pre>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="border-y border-line bg-soft">
    <div class="mx-auto max-w-5xl px-6 py-22">
      <p class="text-[13px] font-semibold tracking-[0.08em] text-accent uppercase">Features</p>
      <h2 class="mt-2.5 text-[32px] font-semibold tracking-[-0.025em]">Small tool, sharp edges</h2>
      <p class="mt-2.5 max-w-[520px] text-muted">
        Everything you need to move links from your browser to your notes — and nothing you
        don't.
      </p>
      <div class="mt-11 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          features.map((f) => (
            <div class="rounded-xl border border-line bg-white p-6 transition-all hover:border-accent/35 hover:shadow-[0_4px_20px_-6px_rgba(14,17,22,0.08)]">
              <span class="inline-flex h-[34px] w-[34px] items-center justify-center rounded-lg bg-accent-soft font-mono text-sm font-medium text-accent">
                {f.icon}
              </span>
              <h3 class="mt-3.5 text-[16.5px] font-semibold tracking-tight">{f.title}</h3>
              <p class="mt-1.5 text-[14.5px] text-muted">{f.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how">
    <div class="mx-auto max-w-5xl px-6 py-22">
      <p class="text-[13px] font-semibold tracking-[0.08em] text-accent uppercase">How it works</p>
      <h2 class="mt-2.5 text-[32px] font-semibold tracking-[-0.025em]">Three steps, ten seconds</h2>
      <div class="mt-11 grid gap-8 sm:grid-cols-3">
        {
          steps.map(([title, body], i) => (
            <div>
              <span class="font-mono text-[13px] font-medium text-accent">0{i + 1}</span>
              <h3 class="mt-2 text-lg font-semibold">{title}</h3>
              <p class="mt-1.5 text-[14.5px] text-muted">{body}</p>
            </div>
          ))
        }
      </div>
      <figure
        class="mt-14 overflow-hidden rounded-xl border border-line shadow-[0_20px_60px_-20px_rgba(14,17,22,0.18)]"
      >
        <Image
          src={screenshot}
          alt="The extension popup showing the copied title and URL of the current tab"
          class="block h-auto w-full"
          loading="eager"
        />
      </figure>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-line bg-soft">
    <div class="mx-auto max-w-5xl px-6 py-24 text-center">
      <h2 class="text-4xl font-semibold tracking-[-0.025em]">Stop hand-writing links.</h2>
      <p class="mx-auto mt-3 max-w-[520px] text-muted">
        Install once, then it's just
        <kbd class="rounded-md border border-b-2 border-line bg-white px-2 py-0.5 font-mono text-xs text-ink"
          >Ctrl</kbd
        > + <kbd
          class="rounded-md border border-b-2 border-line bg-white px-2 py-0.5 font-mono text-xs text-ink"
          >Shift</kbd
        > + <kbd
          class="rounded-md border border-b-2 border-line bg-white px-2 py-0.5 font-mono text-xs text-ink"
          >C</kbd
        >.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3.5">
        <a
          href={storeUrl}
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 rounded-[10px] bg-ink px-5.5 py-3 text-[15px] font-medium text-white shadow-sm transition-all hover:-translate-y-px hover:bg-ink-hover"
        >
          <ChromeIcon />
          Add to Chrome
        </a>
        <a
          href={edgeStoreUrl}
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 rounded-[10px] bg-ink px-5.5 py-3 text-[15px] font-medium text-white shadow-sm transition-all hover:-translate-y-px hover:bg-ink-hover"
        >
          <EdgeIcon />
          Add to Edge
        </a>
      </div>
    </div>
  </section>
</Layout>
